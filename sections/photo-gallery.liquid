<link rel="stylesheet" href="{{ 'photo-gallery.css' | asset_url }}">

<section class="v-carousel" aria-labelledby="GalleryHeading-{{ section.id }}">
  <div class="v-carousel__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <header class="v-carousel__header" data-reveal style="--reveal-i: 0;">
        {%- if section.settings.eyebrow != blank -%}
          <p class="v-eyebrow v-carousel__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="v-carousel__heading" id="GalleryHeading-{{ section.id }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- assign image_blocks = section.blocks | where: 'type', 'image' -%}
    {%- assign total = image_blocks | size -%}

    {%- if total > 0 -%}
      <div
        class="v-carousel__stage"
        data-reveal
        style="--reveal-i: 1;"
        data-carousel
        data-total="{{ total }}"
        data-interval="{{ section.settings.interval | default: 4000 }}"
      >

        <!-- Slides -->
        <div class="v-carousel__track" aria-live="polite">
          {%- for block in image_blocks -%}
            {%- assign slide_hidden = 'true' -%}
            {%- if forloop.first -%}{%- assign slide_hidden = 'false' -%}{%- endif -%}
            <div
              class="v-carousel__slide{% if forloop.first %} is-active{% endif %}"
              aria-hidden="{{ slide_hidden }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.image != blank -%}
                {%- assign img_loading = 'lazy' -%}
                {%- if forloop.first -%}{%- assign img_loading = 'eager' -%}{%- endif -%}
                {{
                  block.settings.image
                  | image_url: width: 1600
                  | image_tag:
                    loading: img_loading,
                    alt: block.settings.alt | default: '',
                    class: 'v-carousel__img',
                    widths: '600,900,1200,1600',
                    sizes: '(min-width: 990px) 80vw, 100vw'
                }}
              {%- else -%}
                <div class="v-carousel__placeholder" aria-hidden="true"></div>
              {%- endif -%}

              {%- if block.settings.caption != blank -%}
                <div class="v-carousel__caption-wrap" aria-hidden="true">
                  <p class="v-carousel__caption v-mono">{{ block.settings.caption }}</p>
                  <span class="v-carousel__scan-line"></span>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        <!-- Arrows -->
        {%- if total > 1 -%}
          <button class="v-carousel__arrow v-carousel__arrow--prev" aria-label="Föregående bild" data-carousel-prev>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M12 4L6 10L12 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="v-carousel__arrow v-carousel__arrow--next" aria-label="Nästa bild" data-carousel-next>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M8 4L14 10L8 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <!-- Dots -->
          <div class="v-carousel__dots" role="tablist" aria-label="Bildnavigation">
            {%- for block in image_blocks -%}
              <button
                class="v-carousel__dot{% if forloop.first %} is-active{% endif %}"
                role="tab"
                aria-selected="{{ forloop.first }}"
                aria-label="Bild {{ forloop.index }}"
                data-carousel-dot="{{ forloop.index0 }}"
              ></button>
            {%- endfor -%}
          </div>

          <!-- Counter -->
          <div class="v-carousel__counter v-mono" aria-hidden="true">
            <span data-carousel-current>01</span>
            <span class="v-carousel__counter-sep">/</span>
            <span>{{ total | prepend: '0' | slice: -2, 2 }}</span>
          </div>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>
</section>

<script src="{{ 'photo-gallery.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Photo gallery",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "GALLERI // VINDA" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sett i verkligheten." },
    {
      "type": "range",
      "id": "interval",
      "label": "Auto-rotate interval (ms)",
      "min": 2000,
      "max": 10000,
      "step": 500,
      "default": 4000
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "text", "id": "caption", "label": "Caption (mono overlay)" }
      ]
    }
  ],
  "presets": [{
    "name": "Photo gallery",
    "blocks": [
      { "type": "image", "settings": { "caption": "VINDA HOME // GARAGEVÄGG" } },
      { "type": "image", "settings": { "caption": "DETALJ // ANSLUTNING" } },
      { "type": "image", "settings": { "caption": "MILJÖ // UPPFART" } },
      { "type": "image", "settings": { "caption": "VINDA GO // BAKLUCKA" } },
      { "type": "image", "settings": { "caption": "DETALJ // KABEL" } },
      { "type": "image", "settings": { "caption": "MILJÖ // LADDNING" } }
    ]
  }]
}
{% endschema %}
