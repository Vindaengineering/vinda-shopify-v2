<link rel="stylesheet" href="{{ 'photo-gallery.css' | asset_url }}">

<section class="v-gallery" aria-labelledby="GalleryHeading-{{ section.id }}">
  <div class="v-gallery__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <header class="v-gallery__header" data-reveal style="--reveal-i: 0;">
        {%- if section.settings.eyebrow != blank -%}
          <p class="v-eyebrow v-gallery__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="v-gallery__heading" id="GalleryHeading-{{ section.id }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="v-gallery__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'image' -%}
          {%- assign img = block.settings.image -%}
          <figure
            class="v-gallery__item v-gallery__item--{{ block.settings.size }}"
            data-reveal
            style="--reveal-i: {{ forloop.index }};"
            {{ block.shopify_attributes }}
          >
            {%- if img != blank -%}
              {{
                img
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  alt: block.settings.alt | default: '',
                  class: 'v-gallery__img',
                  widths: '400,700,1000,1400',
                  sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw'
              }}
            {%- else -%}
              <div class="v-gallery__placeholder" aria-hidden="true"></div>
            {%- endif -%}

            <div class="v-gallery__overlay" aria-hidden="true">
              {%- if block.settings.caption != blank -%}
                <p class="v-gallery__caption v-mono">{{ block.settings.caption }}</p>
              {%- endif -%}
              <span class="v-gallery__scan-line" aria-hidden="true"></span>
            </div>
          </figure>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Photo gallery",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "GALLERI // VINDA" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sett i verkligheten." }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "text", "id": "caption", "label": "Caption (mono overlay)" },
        {
          "type": "select",
          "id": "size",
          "label": "Size",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "wide", "label": "Wide (2 cols)" },
            { "value": "tall", "label": "Tall (2 rows)" }
          ]
        }
      ]
    }
  ],
  "presets": [{
    "name": "Photo gallery",
    "blocks": [
      { "type": "image", "settings": { "caption": "VINDA HOME // GARAGEVÄGG", "size": "wide" } },
      { "type": "image", "settings": { "caption": "DETALJ // ANSLUTNING", "size": "normal" } },
      { "type": "image", "settings": { "caption": "MILJÖ // UPPFART", "size": "normal" } },
      { "type": "image", "settings": { "caption": "VINDA GO // BAKLUCKA", "size": "normal" } },
      { "type": "image", "settings": { "caption": "DETALJ // KABEL", "size": "tall" } },
      { "type": "image", "settings": { "caption": "MILJÖ // LADDNING", "size": "normal" } }
    ]
  }]
}
{% endschema %}
