{{ 'content-page.css' | asset_url | stylesheet_tag }}

<section class="content-page" aria-labelledby="ContentPageHeading-{{ section.id }}">
  <div class="content-page__inner">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

      {%- when 'intro' -%}
        <header class="content-page__intro content-reveal" {{ block.shopify_attributes }}>
          {%- if block.settings.meta_1 != blank or block.settings.meta_2 != blank or block.settings.meta_3 != blank -%}
            <div class="content-page__meta">
              {%- if block.settings.meta_1 != blank -%}<span class="content-page__meta-item">{{ block.settings.meta_1 }}</span>{%- endif -%}
              {%- if block.settings.meta_2 != blank -%}<span class="content-page__meta-item">{{ block.settings.meta_2 }}</span>{%- endif -%}
              {%- if block.settings.meta_3 != blank -%}<span class="content-page__meta-item">{{ block.settings.meta_3 }}</span>{%- endif -%}
            </div>
          {%- endif -%}
          {%- if block.settings.eyebrow != blank -%}
            <p class="content-page__eyebrow">{{ block.settings.eyebrow }}</p>
          {%- endif -%}
          <h1 class="content-page__heading" id="ContentPageHeading-{{ section.id }}">
            {{- block.settings.heading -}}
          </h1>
          {%- if block.settings.lede != blank -%}
            <p class="content-page__lede">{{ block.settings.lede }}</p>
          {%- endif -%}
        </header>

      {%- when 'accordion' -%}
        <section class="content-page__section content-reveal" {{ block.shopify_attributes }}>
          {%- if block.settings.console_label != blank -%}
            <p class="content-page__console">
              <span class="content-page__console-dot" aria-hidden="true"></span>
              {{- block.settings.console_label -}}
            </p>
          {%- endif -%}
          <div class="content-page__accordion" data-content-accordion>
            {%- assign items = block.settings.items_json | strip -%}
            {%- if items != blank -%}
              {%- comment -%} Items come from rich-editor JSON is complex; instead loop over item_N settings. {%- endcomment -%}
            {%- endif -%}
            {%- for i in (1..12) -%}
              {%- assign q_key = 'q_' | append: i -%}
              {%- assign a_key = 'a_' | append: i -%}
              {%- assign q = block.settings[q_key] -%}
              {%- assign a = block.settings[a_key] -%}
              {%- if q != blank -%}
                <div class="content-page__accordion-item">
                  <button
                    class="content-page__accordion-trigger"
                    type="button"
                    aria-expanded="false"
                    aria-controls="AccordionPanel-{{ section.id }}-{{ block.id }}-{{ i }}"
                    id="AccordionTrigger-{{ section.id }}-{{ block.id }}-{{ i }}"
                  >
                    <span>{{ q }}</span>
                    <svg class="content-page__accordion-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <line x1="10" y1="4" x2="10" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      <line x1="4" y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </button>
                  <div
                    class="content-page__accordion-panel"
                    id="AccordionPanel-{{ section.id }}-{{ block.id }}-{{ i }}"
                    role="region"
                    aria-labelledby="AccordionTrigger-{{ section.id }}-{{ block.id }}-{{ i }}"
                  >
                    <div class="content-page__accordion-body">{{ a }}</div>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </section>

      {%- when 'spec_rows' -%}
        <section class="content-page__section content-reveal" {{ block.shopify_attributes }}>
          {%- if block.settings.console_label != blank -%}
            <p class="content-page__console">
              <span class="content-page__console-dot" aria-hidden="true"></span>
              {{- block.settings.console_label -}}
            </p>
          {%- endif -%}
          {%- if block.settings.intro != blank -%}
            <p class="content-page__section-intro">{{ block.settings.intro }}</p>
          {%- endif -%}
          <dl class="content-page__specs">
            {%- for i in (1..10) -%}
              {%- assign l_key = 'label_' | append: i -%}
              {%- assign v_key = 'value_' | append: i -%}
              {%- assign label = block.settings[l_key] -%}
              {%- assign value = block.settings[v_key] -%}
              {%- if label != blank and value != blank -%}
                <div class="content-page__spec-row">
                  <dt class="content-page__spec-label">{{ label }}</dt>
                  <dd class="content-page__spec-value">{{ value }}</dd>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </dl>
        </section>

      {%- when 'step_list' -%}
        <section class="content-page__section content-reveal" {{ block.shopify_attributes }}>
          {%- if block.settings.console_label != blank -%}
            <p class="content-page__console">
              <span class="content-page__console-dot" aria-hidden="true"></span>
              {{- block.settings.console_label -}}
            </p>
          {%- endif -%}
          {%- if block.settings.intro != blank -%}
            <p class="content-page__section-intro">{{ block.settings.intro }}</p>
          {%- endif -%}

          {%- assign step_count = 0 -%}
          {%- for i in (1..6) -%}
            {%- assign t_key = 'title_' | append: i -%}
            {%- if block.settings[t_key] != blank -%}
              {%- assign step_count = step_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}

          <ol class="content-page__steps" role="list">
            {%- assign step_idx = 0 -%}
            {%- for i in (1..6) -%}
              {%- assign t_key = 'title_' | append: i -%}
              {%- assign b_key = 'body_' | append: i -%}
              {%- assign img_key = 'image_' | append: i -%}
              {%- assign tools_key = 'tools_' | append: i -%}
              {%- assign title = block.settings[t_key] -%}
              {%- assign body = block.settings[b_key] -%}
              {%- assign img = block.settings[img_key] -%}
              {%- assign tools = block.settings[tools_key] -%}
              {%- if title != blank -%}
                {%- assign step_idx = step_idx | plus: 1 -%}
                <li class="content-page__step content-reveal" style="--i: {{ step_idx | minus: 1 }};">
                  <div class="content-page__step-media">
                    {%- if img != blank -%}
                      <img
                        class="content-page__step-img"
                        src="{{ img | image_url: width: 1000 }}"
                        srcset="
                          {{ img | image_url: width: 500 }} 500w,
                          {{ img | image_url: width: 800 }} 800w,
                          {{ img | image_url: width: 1200 }} 1200w
                        "
                        sizes="(min-width: 750px) 40vw, 100vw"
                        alt="{{ title | escape }}"
                        width="1000"
                        height="750"
                        loading="lazy"
                      >
                    {%- else -%}
                      <div class="content-page__step-placeholder" aria-hidden="true"></div>
                    {%- endif -%}
                  </div>
                  <div class="content-page__step-body">
                    <p class="content-page__step-num">
                      {%- if step_idx < 10 -%}0{% endif -%}{{ step_idx }}
                      <span class="content-page__step-num-suffix">
                        &nbsp;/&nbsp;
                        {%- if step_count < 10 -%}0{% endif -%}{{ step_count }}
                      </span>
                    </p>
                    <p class="content-page__step-title">{{ title }}</p>
                    {%- if body != blank -%}
                      <div class="content-page__step-text">{{ body }}</div>
                    {%- endif -%}
                    {%- if tools != blank -%}
                      <div class="content-page__step-tools">
                        <span class="content-page__step-tools-label">{{ 'pages.install.tools_label' | t }}</span>
                        <span>{{ tools }}</span>
                      </div>
                    {%- endif -%}
                  </div>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ol>
        </section>

      {%- when 'cta_strip' -%}
        <div class="content-page__cta content-reveal" {{ block.shopify_attributes }}>
          <div class="content-page__cta-text">
            {%- if block.settings.label != blank -%}
              <p class="content-page__cta-meta">
                <span class="content-page__cta-dot" aria-hidden="true"></span>
                {{- block.settings.label -}}
              </p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <p class="content-page__cta-heading">{{ block.settings.heading }}</p>
            {%- endif -%}
          </div>
          {%- if block.settings.button_text != blank and block.settings.button_url != blank -%}
            <a class="content-page__cta-button" href="{{ block.settings.button_url }}">
              {{- block.settings.button_text -}}
              <span aria-hidden="true">→</span>
            </a>
          {%- endif -%}
        </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<script>
  (function () {
    var root = document.documentElement;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* Reveal on scroll */
    var reveals = document.querySelectorAll('.content-reveal:not(.is-visible)');
    if (reveals.length) {
      root.classList.add('content-js');
      if ('IntersectionObserver' in window && !reduced) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.1 });
        reveals.forEach(function (el) { io.observe(el); });
      } else {
        reveals.forEach(function (el) { el.classList.add('is-visible'); });
      }
    }

    /* Accordion */
    document.querySelectorAll('[data-content-accordion] .content-page__accordion-trigger').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        var panel = document.getElementById(btn.getAttribute('aria-controls'));
        if (!panel) return;
        btn.setAttribute('aria-expanded', String(!expanded));
        if (reduced) {
          panel.style.maxHeight = expanded ? '0' : 'none';
          return;
        }
        panel.style.maxHeight = expanded ? '0' : panel.scrollHeight + 'px';
      });
    });
  })();
</script>

