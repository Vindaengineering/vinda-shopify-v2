{%- comment -%}
  Wave 1 placeholder. Replaced in Wave 3 with the 8 design sections.
  Kept so the theme renders something visible while the design system is being built.
{%- endcomment -%}

<section style="min-height: 100vh; display: grid; place-items: center; background: var(--color-bg); padding: calc(var(--header-height) + var(--space-14)) var(--gutter) var(--space-14);">
  <div style="max-width: 720px; text-align: center;">
    <p class="v-eyebrow">Vinda v2 · Wave 1</p>
    <h1 class="v-display" style="font-size: var(--text-hero); margin-bottom: var(--space-6);">
      Foundation laid.
    </h1>
    <p style="color: var(--color-fg-muted); font-size: var(--text-body-lg); line-height: var(--leading-loose);">
      Design tokens, Google fonts, layout shell, and asset pipeline are live.
      Header, footer, hero, and cart will land in subsequent waves.
    </p>
    <div style="margin-top: var(--space-10); display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
      <span class="v-chip">Space Grotesk</span>
      <span class="v-chip">DM Sans</span>
      <span class="v-chip">JetBrains Mono</span>
      <span class="v-chip">#39E614</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wave 1 placeholder",
  "settings": []
}
{% endschema %}
