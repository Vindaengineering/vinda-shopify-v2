<section
  class="v-ba {% if section.settings.background_variant == 'alt' %}v-ba--bg-alt{% endif %}"
  aria-labelledby="BA-{{ section.id }}-heading"
>
  <div class="v-container">
    <div class="v-ba__console" data-reveal>
      <span class="v-ba__console-label v-mono">{{ section.settings.console_label | default: 'INNAN // EFTER' }}</span>
      <span class="v-ba__console-status v-mono">
        <span class="v-ba__dot" aria-hidden="true"></span>
        {{ section.settings.console_status | default: 'DRA FÖR JÄMFÖRELSE' }}
      </span>
    </div>

    <div class="v-ba__head" data-reveal style="--reveal-i: 1;">
      <p class="v-eyebrow">{{ section.settings.eyebrow | default: 'Skillnaden' }}</p>
      <h2 class="v-display v-ba__heading" id="BA-{{ section.id }}-heading">
        {{ section.settings.heading | default: 'Innan Vinda. Efter Vinda.' }}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="v-ba__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div
      class="v-ba__slider"
      data-reveal
      style="--reveal-i: 2;"
      data-ba-slider
      role="group"
      aria-label="{{ section.settings.aria_label | default: 'Innan/efter jämförelse' | escape }}"
    >
      {%- if section.settings.image_after != blank -%}
        <img
          class="v-ba__img v-ba__img--after"
          src="{{ section.settings.image_after | image_url: width: 1600 }}"
          srcset="
            {{ section.settings.image_after | image_url: width: 600 }} 600w,
            {{ section.settings.image_after | image_url: width: 960 }} 960w,
            {{ section.settings.image_after | image_url: width: 1600 }} 1600w
          "
          sizes="(min-width: 990px) 1024px, 100vw"
          alt="{{ section.settings.image_after_alt | escape }}"
          width="1600"
          height="1600"
          loading="lazy"
        >
      {%- else -%}
        <div class="v-ba__placeholder v-ba__placeholder--after" data-label="EFTER" aria-hidden="true"></div>
      {%- endif -%}

      <div class="v-ba__clip" data-ba-slider-clip>
        {%- if section.settings.image_before != blank -%}
          <img
            class="v-ba__img v-ba__img--before"
            src="{{ section.settings.image_before | image_url: width: 1600 }}"
            srcset="
              {{ section.settings.image_before | image_url: width: 600 }} 600w,
              {{ section.settings.image_before | image_url: width: 960 }} 960w,
              {{ section.settings.image_before | image_url: width: 1600 }} 1600w
            "
            sizes="(min-width: 990px) 1024px, 100vw"
            alt="{{ section.settings.image_before_alt | escape }}"
            width="1600"
            height="1600"
            loading="lazy"
          >
        {%- else -%}
          <div class="v-ba__placeholder v-ba__placeholder--before" data-label="INNAN" aria-hidden="true"></div>
        {%- endif -%}
      </div>

      <span class="v-ba__label v-ba__label--before v-mono">{{ section.settings.before_label | default: 'INNAN' }}</span>
      <span class="v-ba__label v-ba__label--after v-mono">{{ section.settings.after_label | default: 'EFTER' }}</span>

      <button
        class="v-ba__handle"
        type="button"
        data-ba-slider-handle
        role="slider"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="50"
        aria-label="{{ section.settings.aria_label | default: 'Innan/efter jämförelse' | escape }}"
      >
        <span aria-hidden="true">↔</span>
      </button>

      <div class="visually-hidden" aria-live="polite" data-ba-slider-announce></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Before / After",
  "settings": [
    { "type": "select", "id": "background_variant", "label": "Background", "default": "default",
      "options": [
        { "value": "default", "label": "Default (#0D0D0D)" },
        { "value": "alt", "label": "Alt (#080808)" }
      ]
    },
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "console_label", "label": "Console label", "default": "INNAN // EFTER" },
    { "type": "text", "id": "console_status", "label": "Console status", "default": "DRA FÖR JÄMFÖRELSE" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Skillnaden" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Innan Vinda. Efter Vinda." },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "header", "content": "Slider" },
    { "type": "image_picker", "id": "image_before", "label": "Before image" },
    { "type": "text", "id": "image_before_alt", "label": "Before alt", "default": "Garage med kabel på golvet" },
    { "type": "image_picker", "id": "image_after", "label": "After image" },
    { "type": "text", "id": "image_after_alt", "label": "After alt", "default": "Vinda monterad, kabel inrullad" },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "INNAN" },
    { "type": "text", "id": "after_label", "label": "After label", "default": "EFTER" },
    { "type": "text", "id": "aria_label", "label": "Slider aria-label", "default": "Innan/efter jämförelse" }
  ],
  "presets": [
    { "name": "Before / After" }
  ]
}
{% endschema %}
