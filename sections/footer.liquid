<link rel="stylesheet" href="{{ 'footer.css' | asset_url }}">

{%- liquid
  assign menu = linklists[section.settings.menu]
  assign year = 'now' | date: '%Y'
-%}

<footer class="v-footer">
  <div class="v-footer__inner">
    <a href="{{ routes.root_url }}" class="v-footer__logo" aria-label="{{ shop.name }}">
      <img
        src="{{ 'logo-outline-white.png' | asset_url }}"
        alt="{{ shop.name }}"
        width="120"
        height="22"
        loading="lazy"
      >
    </a>

    {%- if menu.links.size > 0 -%}
      <nav class="v-footer__nav" aria-label="{{ 'footer.nav_label' | t | default: 'Footer' }}">
        {%- for link in menu.links -%}
          <a href="{{ link.url }}" class="v-footer__link">{{ link.title | escape }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <p class="v-footer__copy">© {{ year }} {{ shop.name }}</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Footer menu", "default": "footer" }
  ]
}
{% endschema %}
