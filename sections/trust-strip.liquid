<section class="v-trust-strip" aria-label="{{ section.settings.aria_label | default: 'Trust signals' }}">
  <div class="v-trust-strip__inner">
    {%- for block in section.blocks -%}
      <div class="v-trust-strip__item" {{ block.shopify_attributes }}>
        {%- case block.settings.icon -%}
          {%- when 'shield-check' -%}{% render 'icon-shield-check' %}
          {%- when 'zap'          -%}{% render 'icon-zap' %}
          {%- when 'cable'        -%}{% render 'icon-cable' %}
          {%- when 'rotate-ccw'   -%}{% render 'icon-rotate-ccw' %}
          {%- when 'award'        -%}{% render 'icon-award' %}
          {%- when 'home'         -%}{% render 'icon-home' %}
          {%- when 'check'        -%}{% render 'icon-check' %}
          {%- else                -%}{% render 'icon-shield-check' %}
        {%- endcase -%}
        <span>{{ block.settings.label }}</span>
      </div>
      {%- unless forloop.last -%}<span class="v-trust-strip__sep" aria-hidden="true"></span>{%- endunless -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust strip",
  "settings": [],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust item",
      "limit": 6,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "shield-check",
          "options": [
            { "value": "shield-check", "label": "Shield check" },
            { "value": "zap", "label": "Zap" },
            { "value": "cable", "label": "Cable" },
            { "value": "rotate-ccw", "label": "Rotate" },
            { "value": "award", "label": "Award" },
            { "value": "home", "label": "Home" },
            { "value": "check", "label": "Check" }
          ]
        },
        { "type": "text", "id": "label", "label": "Label", "default": "IP44 Rated" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust strip",
      "blocks": [
        { "type": "trust", "settings": { "icon": "shield-check", "label": "IP44 Rated" } },
        { "type": "trust", "settings": { "icon": "zap", "label": "Up to 11 kW" } },
        { "type": "trust", "settings": { "icon": "cable", "label": "Type 2 Connector" } },
        { "type": "trust", "settings": { "icon": "rotate-ccw", "label": "Auto-Retractable" } },
        { "type": "trust", "settings": { "icon": "award", "label": "CE Certified" } }
      ]
    }
  ]
}
{% endschema %}
