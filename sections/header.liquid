<link rel="stylesheet" href="{{ 'header.css' | asset_url }}">
<script src="{{ 'header.js' | asset_url }}" defer></script>

{%- liquid
  assign menu = linklists[section.settings.menu]
  assign about_url = section.settings.about_url
-%}

<header class="v-header" id="VHeader" data-scroll-state="top">
  <div class="v-header__inner">
    <a href="{{ routes.root_url }}" class="v-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{- section.settings.logo
            | image_url: width: 240
            | image_tag: loading: 'eager', alt: shop.name, class: 'v-header__logo-img', width: 120, height: 28 -}}
      {%- else -%}
        <img
          src="{{ 'logo-outline-white.png' | asset_url }}"
          alt="{{ shop.name }}"
          class="v-header__logo-img"
          width="120"
          height="28"
          loading="eager"
        >
      {%- endif -%}
    </a>

    {%- if menu.links.size > 0 -%}
      <nav class="v-header__nav" aria-label="{{ 'accessibility.main_navigation' | t }}">
        <ul role="list">
          {%- for link in menu.links -%}
            <li>
              <a href="{{ link.url }}" class="v-header__nav-link">{{ link.title | escape }}</a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <div class="v-header__utils">
      {%- if about_url != blank -%}
        <a href="{{ about_url }}" class="v-header__nav-link v-header__about">{{ 'header.about' | t | default: 'About' }}</a>
      {%- endif -%}

      <button
        type="button"
        class="v-header__cart"
        data-cart-open
        aria-label="{{ 'header.cart_label' | t | default: 'Open cart' }}"
      >
        {% render 'icon-shopping-cart' %}
        <span>{{ 'header.cart' | t | default: 'Cart' }}</span>
        <span class="v-header__cart-count{% if cart.item_count == 0 %} is-empty{% endif %}" data-cart-count>
          {{- cart.item_count -}}
        </span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image (optional, falls back to outline white)" },
    { "type": "link_list",   "id": "menu", "label": "Main menu", "default": "main-menu" },
    { "type": "url",         "id": "about_url", "label": "About link URL" }
  ]
}
{% endschema %}
