<section class="v-features" id="features" aria-labelledby="FeaturesHeading">
  <div class="v-container">
    <header class="v-features__header" data-reveal>
      <p class="v-eyebrow">{{ section.settings.eyebrow | default: 'Technology' }}</p>
      <h2 class="v-display v-features__heading" id="FeaturesHeading">
        {{ section.settings.heading | default: 'Engineering that disappears.' }}
      </h2>
    </header>

    <div class="v-features__grid">
      {%- for block in section.blocks -%}
        <article class="v-features__tile" {{ block.shopify_attributes }} data-reveal style="--reveal-i: {{ forloop.index }};">
          <div class="v-features__icon">
            {%- case block.settings.icon -%}
              {%- when 'rotate-ccw'   -%}{% render 'icon-rotate-ccw' %}
              {%- when 'shield-check' -%}{% render 'icon-shield-check' %}
              {%- when 'zap'          -%}{% render 'icon-zap' %}
              {%- when 'cable'        -%}{% render 'icon-cable' %}
              {%- when 'home'         -%}{% render 'icon-home' %}
              {%- when 'award'        -%}{% render 'icon-award' %}
              {%- else                -%}{% render 'icon-zap' %}
            {%- endcase -%}
          </div>
          <h3 class="v-features__title">{{ block.settings.title }}</h3>
          <p class="v-features__body">{{ block.settings.body }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Technology" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Engineering that disappears." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature tile",
      "limit": 4,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "rotate-ccw",
          "options": [
            { "value": "rotate-ccw", "label": "Rotate" },
            { "value": "shield-check", "label": "Shield check" },
            { "value": "zap", "label": "Zap" },
            { "value": "cable", "label": "Cable" },
            { "value": "home", "label": "Home" },
            { "value": "award", "label": "Award" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Auto-retract" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Spring-loaded mechanism. Perfectly coiled every time, without thinking about it." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features",
      "blocks": [
        { "type": "feature", "settings": { "icon": "rotate-ccw", "title": "Auto-retract", "body": "Spring-loaded mechanism. Perfectly coiled every time, without thinking about it." } },
        { "type": "feature", "settings": { "icon": "shield-check", "title": "IP44 rated", "body": "Sealed for outdoor use year-round. Built for Scandinavian winters." } },
        { "type": "feature", "settings": { "icon": "zap", "title": "Up to 11 kW", "body": "Three-phase charging at full speed. Your car is ready every morning." } },
        { "type": "feature", "settings": { "icon": "home", "title": "Built for homes", "body": "Compact footprint. Discreet matte finish. Fits any exterior surface." } }
      ]
    }
  ]
}
{% endschema %}
