<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0D0D0D">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    {%- comment -%} ── Fonts: Google Fonts CDN per design ─────── {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    {%- comment -%} ── Tokens (inline-load) + storefront base ─── {%- endcomment -%}
    <link rel="stylesheet" href="{{ 'tokens.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'storefront.css' | asset_url }}">

    {%- comment -%} ── LCP preload: hero lifestyle on home only ── {%- endcomment -%}
    {%- if request.page_type == 'index' -%}
      <link rel="preload" as="image" href="{{ 'lifestyle-driveway.jpg' | asset_url }}">
    {%- endif -%}

    <script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>
    <script src="{{ 'reveal.js' | asset_url }}" defer></script>
    <script src="{{ 'before-after.js' | asset_url }}" defer></script>

    {{ content_for_header }}
  </head>

  <body class="page-{{ request.page_type | handle }}">
    <a class="skip-link" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- comment -%} ── Cart drawer + sticky bar are global UI ──── {%- endcomment -%}
    {% section 'cart-drawer' %}
    {% section 'sticky-cart-bar' %}

    <style>
      .skip-link {
        position: absolute; left: -9999px; top: 0;
        background: var(--color-accent); color: var(--color-bg);
        padding: 12px 20px; font-family: var(--font-body); font-weight: 700;
        z-index: 9999;
      }
      .skip-link:focus { left: 16px; top: 16px; }
    </style>
  </body>
</html>
